<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main shadow behind thickness -->
    <item android:bottom="4dp" android:right="3dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#50000000"
                android:endColor="#00000000"/>
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="4dp"
                android:bottomRightRadius="24dp"/>
        </shape>
    </item>
    <!-- Page block base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#F0EBE3"/>
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="4dp"
                android:bottomRightRadius="24dp"/>
        </shape>
    </item>
    <!-- Top shadow (cover overlap) -->
    <item android:bottom="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#2A000000"
                android:endColor="#00000000"/>
        </shape>
    </item>
    <!-- Page lines -->
    <item android:top="4dp" android:bottom="9dp">
        <shape android:shape="rectangle">
            <solid android:color="#1C000000"/>
        </shape>
    </item>
    <item android:top="7dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#1C000000"/>
        </shape>
    </item>
    <item android:top="10dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#1C000000"/>
        </shape>
    </item>
    <!-- Rim light on page edge -->
    <item android:top="0dp" android:left="0dp" android:right="2dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#18FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="90"/>
            <corners
                android:topLeftRadius="0dp"
                android:topRightRadius="0dp"
                android:bottomLeftRadius="4dp"
                android:bottomRightRadius="0dp"/>
        </shape>
    </item>
</layer-list>
