<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <solid android:color="#50FFFFFF"/>
                    <stroke android:width="1.5dp" android:color="#70FFFFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <!-- Soft shadow -->
            <item android:bottom="2dp" android:right="1dp">
                <shape android:shape="oval">
                    <solid android:color="#30000000"/>
                </shape>
            </item>
            <!-- Glass body -->
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:startColor="#35FFFFFF"
                        android:endColor="#12FFFFFF"
                        android:angle="45"/>
                    <stroke android:width="1dp" android:color="#30FFFFFF"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
