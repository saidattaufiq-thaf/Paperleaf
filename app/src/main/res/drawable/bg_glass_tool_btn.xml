<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#45FFFFFF"
                android:endColor="#20FFFFFF"
                android:angle="45"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="1dp"
                android:color="#60FFFFFF"/>
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#30FFFFFF"
                android:endColor="#15FFFFFF"
                android:angle="45"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="1.5dp"
                android:color="#70FFFFFF"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#18FFFFFF"
                android:endColor="#08FFFFFF"
                android:angle="45"/>
            <corners android:radius="12dp"/>
            <stroke
                android:width="0.5dp"
                android:color="#15FFFFFF"/>
        </shape>
    </item>
</selector>
